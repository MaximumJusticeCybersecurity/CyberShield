  "public_artifact_name": "AI Trust Decision Record",
  "primary_wedge": "vendor-risk",
  "route_strategy": "Keep /vendor-risk.html stable. Use /vendor-risk-next.html for richer panels until tested.",
  "doctrine": [
    "AI confidence is not evidence.",
    "The record is the product.",
    "Vendor risk is the first wedge.",
    "Aegis remains internal for this build.",
