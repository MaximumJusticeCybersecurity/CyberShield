  "refusal_response": "This action is refused by constraint until current banking verification and controller approval are present.",
  "logging_requirement": "Create decision record and protocol basis proof entry.",
  "escalation_owner": "Controller",
  "decision_state": "Refused by Constraint / Escalate",
  "proof_pack_mapping": "protocol_basis.vendor_payment_change_30d",
