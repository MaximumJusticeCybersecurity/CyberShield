{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maximumjusticecybersecurity.github.io/CyberShield/schemas/model.schema.json",
  "title": "CyberShield Scoring Model",
  "type": "object",
  "required": ["model_id", "model_name", "model_version", "model_status", "purpose", "score_range", "inputs", "source_frameworks", "limitations"],
  "properties": {
    "model_id": {"type": "string"},
    "model_name": {"type": "string"},
    "model_version": {"type": "string"},
    "model_status": {"type": "string", "enum": ["demo_directional_not_certified", "assessment_driven", "analyst_assisted", "pilot_validated", "production_calibrated"]},
    "model_owner": {"type": "string"},
    "last_updated": {"type": "string"},
    "purpose": {"type": "string"},
    "score_range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
    "inputs": {"type": "array", "items": {"type": "object"}},
    "weights": {"type": ["array", "object"]},
    "thresholds": {"type": ["array", "object"]},
    "decision_rules": {"type": ["array", "object"]},
    "evidence_requirements": {"type": "array", "items": {"type": "string"}},
    "source_frameworks": {"type": "array", "items": {"type": "string"}},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "change_log": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
