{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CyberShield Industry Profile Registry",
  "type": "object",
  "required": ["registry_id", "registry_version", "industries"],
  "properties": {
    "registry_id": {"type": "string"},
    "registry_version": {"type": "string"},
    "industries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["industry_id", "label"],
        "properties": {
          "industry_id": {"type": "string"},
          "label": {"type": "string"},
          "frameworks": {"type": "array", "items": {"type": "string"}},
          "primary_scenarios": {"type": "array", "items": {"type": "string"}},
          "primary_reports": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
