{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maximumjusticecybersecurity.github.io/CyberShield/schemas/role-profile.schema.json",
  "title": "CyberShield Role Profile Registry",
  "type": "object",
  "required": ["registry_id", "registry_version", "roles"],
  "properties": {
    "registry_id": {"type": "string"},
    "registry_version": {"type": "string"},
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role_id", "label", "dashboard_lens"],
        "properties": {
          "role_id": {"type": "string"},
          "label": {"type": "string"},
          "dashboard_lens": {"type": "string"},
          "focus": {"type": "array", "items": {"type": "string"}},
          "primary_reports": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
